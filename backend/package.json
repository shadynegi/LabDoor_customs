{
  "name": "server",
  "version": "1.0.0",
  "description": "Backend API for Lab Door Customs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node ../Tests/scripts/run-with-report.mjs vitest",
    "test:watch": "vitest",
    "test:unit": "node ../Tests/scripts/run-with-report.mjs unit",
    "test:api": "node ../Tests/scripts/run-with-report.mjs api",
    "test:raw": "vitest run",
    "keep-alive": "node scripts/keep-alive.js",
    "validate-env": "node scripts/validate-env.mjs"
  },
  "dependencies": {
    "@sentry/node": "^10.58.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.7",
    "rate-limit-redis": "^5.0.0",
    "redis": "^6.0.0",
    "resend": "^6.8.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^20.19.25",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
