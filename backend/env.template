# Server Configuration
PORT=5000
HTTPS_PORT=443
NODE_ENV=development

# Public site URL (CORS + CSP + PayPal return URLs). In unified deploy this is the same host as the API.
FRONTEND_URL=http://localhost:5173

# Serve frontend/dist from this Express process (auto-enabled in production when dist exists).
# SERVE_FRONTEND=true
# FRONTEND_DIST_PATH=../frontend/dist

# Public API host (optional fallback for HTTP→HTTPS 301 redirect)
# PUBLIC_HOST=api.yourdomain.com

# Cloudflare proxy (REQUIRED in production) — trust CF-Connecting-IP; block direct origin access
# TRUST_CLOUDFLARE=true

# SSL/HTTPS Configuration (Required for production)
# Generate certificates using Let's Encrypt (certbot) or your CA
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_CA_PATH=/etc/letsencrypt/live/yourdomain.com/chain.pem

# IP Anonymization Salt (for GDPR compliance; required in production)
IP_SALT=your_random_ip_anonymization_salt

# Order access token encryption (32+ chars; required in production — openssl rand -base64 32)
ORDER_TOKEN_ENCRYPTION_KEY=your_order_token_encryption_key_at_least_32_chars

# Database Configuration
# Direct connection (migrations/admin tasks):
# DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres
# PgBouncer pooler (recommended for production app servers — port 6543):
DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:6543/postgres?pgbouncer=true
# Force pooler mode when host does not include "pooler" (sets prepare=false):
# DB_USE_POOLER=true
# Pool max: default 5 with pooler, 10 without. Keep low with PgBouncer.
DB_POOL_MAX=5
# Per-query statement timeout in ms (default 300000 — avoids Supabase pooler cancel during bootstrap)
# DB_STATEMENT_TIMEOUT_MS=300000
# TLS: set DB_SSL_CA_PATH to Supabase/Railway CA bundle in production (rejectUnauthorized defaults true)
# DB_SSL_CA_PATH=/path/to/prod-ca.crt
# DB_SSL_REJECT_UNAUTHORIZED=false  # emergency only — not recommended

# Redis (REQUIRED in production) — distributed cache + rate limits across instances
# REDIS_URL=redis://default:password@your-redis-host:6379

# Abandoned checkout cleanup (hours before pending orders are cancelled + stock restored)
# PENDING_ORDER_TTL_HOURS=24

# Stuck payment idempotency reaper (minutes in 'processing' before marked failed)
# IDEMPOTENCY_STALE_MINUTES=5
# IDEMPOTENCY_REAP_BATCH_SIZE=50
# IDEMPOTENCY_REAP_MAX_BATCHES=10
# Delay first maintenance run after bootstrap (ms; default 30000 dev, 120000 production)
# MAINTENANCE_DEFER_MS=30000
# Skip idempotency reaper during maintenance (dev workaround if partial index missing)
# MAINTENANCE_SKIP_IDEMPOTENCY_REAP=true
# Dev only: wait for RLS migration before marking API ready (production always blocks)
# BOOTSTRAP_BLOCK_UNTIL_RLS=true
# Dev only: block API until full bootstrap finishes (default: API ready immediately in dev)
# BOOTSTRAP_BLOCK_API=true
# Skip boot-time CREATE TABLE/INDEX when schema already applied in Supabase SQL editor
# BOOTSTRAP_SKIP_DDL=true
# Drop legacy RLS policies on boot (default: skip — use migration-performance-linter-fixes.sql instead)
# BOOTSTRAP_FORCE_RLS=true
# DB ping timeout during bootstrap (ms, default 20000)
# BOOTSTRAP_PING_TIMEOUT_MS=20000
REQUEST_TIMEOUT_MS=60000
# Slow routes: catalog GET, admin analytics, activity (default 180000)
# SLOW_REQUEST_TIMEOUT_MS=180000
PAYPAL_HTTP_TIMEOUT_MS=10000

# Logging (Pino — JSON in production, pretty in development)
# LOG_LEVEL=info

# Error tracking (optional — https://sentry.io)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Analytics & Search Console (optional — admin dashboard shows status)
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GSC_SITE_URL=https://www.yourdomain.com

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_key

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox
# Use 'sandbox' for testing, 'live' for production
# Required in production — from PayPal Developer Dashboard → Webhooks
# PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# Admin Authentication (REQUIRED)
ADMIN_USERNAME=your_admin_username
# Generate with: node -e "const b=require('bcrypt');b.hash('your-password',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$your_bcrypt_hash_here
JWT_SECRET=your_secure_jwt_secret_at_least_32_characters_long

# Order tokens & privacy (REQUIRED in production)
ORDER_TOKEN_ENCRYPTION_KEY=your_32_character_encryption_key_here
IP_SALT=random_salt_for_ip_anonymization

# Email Service Configuration (REQUIRED for notifications)
RESEND_API_KEY=your_resend_api_key
SENDER_EMAIL=noreply@yourdomain.com
COMPANY_NAME=Lab Door Customs
COMPANY_SUPPORT_EMAIL=support@yourdomain.com
