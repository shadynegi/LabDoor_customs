# API Configuration (development)
# Relative /api — Vite proxies to the backend (works on LAN devices on same Wi‑Fi).
VITE_API_BASE_URL=/api

# Optional: direct backend URL when not using Vite proxy
# VITE_API_BASE_URL=http://localhost:5000/api

# Backend origin for non-API calls (optional in dev)
# VITE_BACKEND_URL=http://localhost:5000

# Production (Railway build on same host as API)
# VITE_API_BASE_URL=/api
# VITE_SITE_URL=https://www.yourdomain.com

# API request timeout (ms, default 60000)
# VITE_API_TIMEOUT_MS=60000

# Slow DB-heavy routes: catalog, analytics, activity (ms, default 180000)
# VITE_EXTENDED_API_TIMEOUT_MS=180000

# Canonical public site URL (no trailing slash) — SEO, OG tags, sitemap
# VITE_SITE_URL=https://www.labdoorcustoms.com

# Google Analytics 4 (production only; loads after analytics cookie consent)
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console HTML meta verification (injected at app startup)
# VITE_GSC_VERIFICATION=your_verification_token_from_search_console

# Sitemap generation (build / CI — fetches live product URLs from API)
# SITEMAP_API_BASE_URL=https://www.yourdomain.com/api
# SITEMAP_REQUIRE_PRODUCTS=true

# Sentry error tracking (required in production/CI builds)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Store WhatsApp contact (must match backend WHATSAPP_CONTACT_NUMBER).
# Default matches Tests/scripts/run-with-report.mjs and contact E2E specs.
VITE_WHATSAPP_CONTACT_NUMBER=+919888514572

