{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "validate-env": "node scripts/validate-env.mjs",
    "build": "npm run validate-env && npm run sitemap && tsc -b && vite build",
    "build:analyze": "ANALYZE=true tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --port 5173",
    "test:e2e": "npm run test:frontend --prefix ../Tests",
    "test:e2e:install": "npm run test:frontend:install --prefix ../Tests",
    "start": "serve -s dist -l ${PORT:-5173}"
  },
  "dependencies": {
    "@sentry/react": "^10.55.0",
    "country-list": "^2.4.1",
    "framer-motion": "^12.23.24",
    "fuse.js": "^7.3.0",
    "liquid-web": "^1.1.1",
    "lucide-react": "^0.553.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "react-select": "^5.10.2",
    "serve": "^14.2.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/country-list": "^2.1.4",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2"
  }
}
