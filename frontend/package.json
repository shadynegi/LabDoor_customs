{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "validate-env": "node scripts/validate-env.mjs",
    "optimize-assets": "node scripts/optimize-assets.mjs",
    "measure:dist": "node scripts/measure-dist.mjs",
    "build:budget": "node scripts/build-budget.mjs",
    "build": "npm run validate-env && npm run optimize-assets && npm run sitemap && tsc -b && vite build && npm run build:budget",
    "build:analyze": "ANALYZE=true tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --port 5173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:frontend --prefix ../Tests",
    "test:e2e:install": "npm run test:frontend:install --prefix ../Tests",
    "start": "serve -s dist -l ${PORT:-5173}"
  },
  "dependencies": {
    "@sentry/react": "^10.63.0",
    "country-list": "^2.4.1",
    "framer-motion": "^12.23.24",
    "liquid-web": "^1.1.1",
    "lucide-react": "^0.553.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.9.6",
    "serve": "^14.2.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/country-list": "^2.1.4",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "sharp": "^0.35.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
